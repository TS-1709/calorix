[Unit]
Description=Calorix Privacy-First Meal Coach
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/root/calorix
ExecStart=/root/.nvm/versions/node/v24.14.0/bin/npx vite preview --host 0.0.0.0 --port 5299
Restart=always
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
